# ============================================================
# Hermes Grant Scout — Шаблон змінних середовища
# ============================================================
# 1. Скопіюйте цей файл: cp .env.template .env
# 2. Заповніть всі значення
# 3. НІКОЛИ не комітьте .env у git!
# Детальна інструкція: docs/SETUP_APIS.md

# --- OpenRouter (LLM бекенд) ---
# Реєстрація: https://openrouter.ai
# Keys → Create Key
OPENROUTER_API_KEY=

# --- Telegram ---
# Токен вашого бота від @BotFather
TELEGRAM_BOT_TOKEN=
# Ваш числовий Telegram user ID (отримати через @userinfobot)
TELEGRAM_CHAT_ID=

# --- Notion ---
# Settings → Integrations → New Integration → copy "Internal Integration Token"
NOTION_API_KEY=
# ID сторінки Notion, де буде створена база даних
# URL сторінки виглядає як: notion.so/Назва-сторінки-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Скопіюйте 32-символьний рядок після останнього дефісу
NOTION_PAGE_ID=

# --- Web Search Settings ---
# Провайдер пошуку: serper (Google Search API через Serper.dev) або duckduckgo (Безкоштовно)
SEARCH_PROVIDER=duckduckgo

# Для serper (реєстрація на https://serper.dev):
SERPER_API_KEY=

# --- GCP (для deploy-gcp.sh) ---
# ID вашого GCP проєкту (не назва, а ID)
GCP_PROJECT_ID=
# Ім'я VM (можна залишити за замовчуванням)
GCP_VM_NAME=
GCP_ZONE=
